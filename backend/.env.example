# -----------------------------------------------------------------------------
# Base de datos (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/parcial_db


# -----------------------------------------------------------------------------
# JWT — Autenticación
# -----------------------------------------------------------------------------
# Generá un secreto fuerte con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_super_secret_key_minimo_32_chars

JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7


# -----------------------------------------------------------------------------
# Cookies
# -----------------------------------------------------------------------------
COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token

# En producción cambiar a: COOKIE_SECURE=true  /  COOKIE_SAMESITE=strict
COOKIE_SECURE=false
COOKIE_SAMESITE=lax


# -----------------------------------------------------------------------------
# CORS — Orígenes permitidos
# -----------------------------------------------------------------------------
# Lista JSON. Agregá los puertos del frontend que uses.
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174","http://127.0.0.1:5173","http://127.0.0.1:5174"]


# -----------------------------------------------------------------------------
# Cloudinary — Almacenamiento de imágenes
# -----------------------------------------------------------------------------
# Obtené tus credenciales en: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret


# -----------------------------------------------------------------------------
# Rate limiting (TokenBucket)
# -----------------------------------------------------------------------------
# Rutas generales: 60 req/min, burst de 10
RATE_LIMIT_DEFAULT_BURST=10
RATE_LIMIT_DEFAULT_PER_MINUTE=60.0

# Rutas de autenticación: 5 req/15min (~0.33/min), burst de 5
RATE_LIMIT_AUTH_BURST=5
RATE_LIMIT_AUTH_PER_MINUTE=0.33


# -----------------------------------------------------------------------------
# Seguridad — Hashing de contraseñas
# -----------------------------------------------------------------------------
BCRYPT_ROUNDS=12
EOF